# Variables de entorno opcionales para el Portfolio Tracker.
# Copiar como `.env.local` y rellenar lo que necesites.
#
# `.env.local` está en .gitignore — NUNCA commitear API keys.

# ─── Google Gemini (parser del chat — proveedor primario, GRATIS) ─────────
# Free tier: 15 RPM, 1500 reqs/día. Sin tarjeta de crédito.
# Sin esta key el chat cae al regex stub local (parseo limitado).
# Obtenerla en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ─── Twelve Data (precios subyacentes USA — opcional) ─────────────────────
# Free tier: 800 calls/día, 8 calls/min. Para CEDEAR breakdown.
# Sin esta key el breakdown del subyacente se deriva del precio ARS / CCL.
# Obtenerla GRATIS en: https://twelvedata.com/pricing (10s, sin tarjeta)
VITE_TWELVEDATA_KEY=

# ─── Anthropic Claude (parser del chat — opcional, mejor calidad pero pago) ─
# No tiene free tier real. Si está config + Gemini, se usa Gemini.
# Solo agregar si querés forzar Claude pagando.
VITE_ANTHROPIC_API_KEY=
